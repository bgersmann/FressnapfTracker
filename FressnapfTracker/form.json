            "onClick": "FRT_getSmsCode($id);",
            "visible": true,
            "width": ""
        },
        {
            "type": "Button",
            "caption": "SMS Verifizieren",
            "confirm": "",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "verifySmsCode",
            "onClick": "FRT_authenticateSMSCode($id);",
            "visible": true,
            "width": ""
        },
        {
            "type": "Button",
            "caption": "Devices auslesen",
            "confirm": "",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "readDevice",
            "onClick": "FRT_getDevices($id);",
            "visible": true,
            "width": ""
        },
        {
            "type": "Button",
            "caption": "Device Daten holen",
            "confirm": "",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "readDeviceData",
            "onClick": "FRT_getDeviceData($id);",
            "visible": true,
            "width": ""
        }
