{
    "elements": [
        {
            "type": "CheckBox",
            "caption": "Aktiv",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "active",
            "onChange": "",
            "value": false,
            "visible": true,
            "width": ""
        },
        {
            "type": "NumberSpinner",
            "caption": "Timer (sekunden):",
            "digits": 0,
            "enabled": true,
            "hex": false,
            "maximum": null,
            "minimum": null,
            "moreDigits": false,
            "name": "Timer",
            "onChange": "",
            "suffix": "",
            "value": 0,
            "visible": true,
            "width": "300px"
        },
        {
            "type": "Label",
            "bold": false,
            "caption": "Bitte Handynummer eintragen (Format:+4917012345678) und \"Änderungen übernehmen\". Danach \"SMS Anfordern\".",
            "color": 0,
            "italic": false,
            "link": true,
            "name": "",
            "underline": false,
            "visible": true,
            "width": ""
        },
        {
            "type": "Label",
            "bold": false,
            "caption": "Den Code eintragen -> Änderungen übernehmen und \"SMS Verifizieren\". -> Danach \"Devices auslesen\" und Serial auswählen.",
            "color": 0,
            "italic": false,
            "link": true,
            "name": "",
            "underline": false,
            "visible": true,
            "width": ""
        },
        {
            "type": "ValidationTextBox",
            "caption": "Handynummer:",
            "enabled": true,
            "multiline": false,
            "name": "phoneNumber",
            "onChange": "",
            "validate": "^\\+49[1-9][0-9]{1,14}$",
            "value": "0",
            "visible": true,
            "width": "300px"
        },
        {
            "type": "ValidationTextBox",
            "caption": "SMS Code:",
            "enabled": true,
            "multiline": false,
            "name": "smsCode",
            "onChange": "",
            "validate": "^[0-9]{6}$",
            "value": "0",
            "visible": true,
            "width": "300px"
        },
        {
            "type": "Select",
            "caption": "Tracker Serial:",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "TrackerID",
            "options": [],
            "onChange": "",
            "value": "",
            "visible": true,
            "width": "300px"
        },
        {
            "type": "CheckBox",
            "caption": "Hunderunde speichern",
            "download": "",
            "enabled": true,
            "link": false,
            "name": "trackRecording",
            "onChange": "",
            "value": false,
            "visible": true,
            "width": ""
        },
        {
            "type": "ExpansionPanel",
            "caption": "Gassi-Runden Erkennung",
            "items": [
                {
                    "type": "Label",
                    "caption": "Koordinaten werden automatisch aus der Location Control übernommen; das Archiv stammt aus dem Archive Control.",
                    "visible": true
                },
                {
                    "type": "CheckBox",
                    "caption": "Koordinaten aus Location Control übernehmen",
                    "enabled": true,
                    "name": "useLocationControl",
                    "value": true,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "Label",
                    "caption": "Wenn deaktiviert, werden die folgenden manuellen Koordinaten verwendet.",
                    "visible": true
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Manuelle Latitude (°)",
                    "digits": 6,
                    "enabled": true,
                    "maximum": 90,
                    "minimum": -90,
                    "name": "manualHomeLatitude",
                    "value": 0,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Manuelle Longitude (°)",
                    "digits": 6,
                    "enabled": true,
                    "maximum": 180,
                    "minimum": -180,
                    "name": "manualHomeLongitude",
                    "value": 0,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Haus-Radius (m)",
                    "digits": 0,
                    "enabled": true,
                    "name": "homeRadius",
                    "value": 50,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Zusätzliche Austritts-Toleranz (m)",
                    "digits": 0,
                    "enabled": true,
                    "name": "homeLeaveMargin",
                    "value": 20,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Max. Gehgeschwindigkeit (km/h)",
                    "digits": 1,
                    "enabled": true,
                    "name": "maxWalkSpeedKmh",
                    "value": 25,
                    "visible": true,
                    "width": "300px"
                },
                {
                    "type": "NumberSpinner",
                    "caption": "Auswertungsfenster (h)",
                    "digits": 0,
                    "enabled": true,
                    "name": "trackLookbackHours",
                    "value": 6,
                    "visible": true,
                    "width": "300px"
                }
            ],
            "visible": true
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "SMS Anfordern",
            "confirm": "",
            "download": "",
